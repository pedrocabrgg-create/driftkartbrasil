# ============================================================
# Drift Kart Brasil — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite .env.local
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_publica
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_secreta

# Resend (e-mail transacional)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@driftkartbrasil.com.br

# WhatsApp (número sem formatação: 55 + DDD + número)
NEXT_PUBLIC_WHATSAPP_NUMBER=5511976626414

# Anthropic (geração de sugestões de posts via IA)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Chave Pix (a confirmar com o cliente)
# NEXT_PUBLIC_PIX_KEY=

# URL da aplicação (usada em e-mails e SEO)
NEXT_PUBLIC_APP_URL=https://www.driftkartbrasil.com.br

# Cron secret (protege a rota /api/cron/* do Vercel Cron)
CRON_SECRET=gere_um_secret_longo_e_aleatorio

# Ambiente
NODE_ENV=development
